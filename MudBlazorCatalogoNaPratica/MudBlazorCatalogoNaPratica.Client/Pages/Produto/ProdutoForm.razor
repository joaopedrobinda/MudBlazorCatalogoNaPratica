<MudForm @ref="form" @bind-IsValid="@_isFormValid">
    <MudGrid Spacing="2">
        <MudItem xs="12" sm="8">
            <MudTextField @bind-Value="Produto.Nome"
                          For="@(() => Produto.Nome)"
                          Label="Nome do Produto"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Required="true"
                          Immediate="true" />
        </MudItem>
        
        @* Preço com Formatação de Moeda *@
        <MudItem xs="12" sm="4">
            <MudNumericField @bind-Value="Produto.Preco"
                             For="@(() => Produto.Preco)"
                             Label="Preço"
                             Variant="Variant.Outlined"
                             Margin="Margin.Dense"
                             Format="C2"
                             Culture="@_brazilCulture"
                             Adornment="Adornment.Start"
                             HideSpinButtons="true"
                             Required="true" />
        </MudItem>
        
        @* Linha 2: Descrição *@
        <MudItem xs="12">
            <MudTextField @bind-Value="Produto.Descricao"
                          For="@(() => Produto.Descricao)"
                          Label="Descrição Detalhada"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Lines="3" 
                          Required="true" />
        </MudItem>

        @* Linha 3: Categoria com Select *@
        <MudItem xs="12" sm="6">
            <MudSelect T="int"
                       Label="Categoria"
                       @bind-Value="Produto.CategoriaId"
                       For="@(() => Produto.CategoriaId)"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       AnchorOrigin="Origin.BottomCenter"
                       TransformOrigin="Origin.TopCenter"
                       MaxHeight="250"
                       Dense="true"
                       Required="true"
                       Adornment="Adornment.Start">

                @* Item placeholder — desabilitado, impede o "0" aparecer selecionado *@
                <MudSelectItem T="int" Value="0" Disabled="true">
                    Selecione uma categoria
                </MudSelectItem>
                @if (Categorias != null)
                {
                    @foreach (var cat in Categorias)
                    {
                        <MudSelectItem Value="@cat.CategoriaId">@cat.Name</MudSelectItem>
                    }
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" Class="d-flex justify-space-between align-center mt-1">
            <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="OnCancel">
                Cancelar
            </MudButton>
            
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="@(!_isFormValid || IsSaving)"
                       OnClick="HandleSubmit">
                @if (IsSaving)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Salvando...</MudText>
                }
                else
                {
                    <MudText>@ButtonText</MudText>
                }
            </MudButton>
        </MudItem>
    </MudGrid>
</MudForm>

@code {
    private MudForm? form;
    private bool _isFormValid;

    private System.Globalization.CultureInfo _brazilCulture = System.Globalization.CultureInfo.GetCultureInfo("pt-BR");

    [Parameter] public List<Categoria>? Categorias { get; set; }
    [Parameter] public Produto Produto { get; set; } = new();
    [Parameter] public bool IsSaving { get; set; }
    [Parameter] public string ButtonText { get; set; } = "Salvar";
    [Parameter] public EventCallback OnValidSubmit { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private async Task HandleSubmit()
    {
        await form!.ValidateAsync();
        if (form.IsValid)
        {
            await OnValidSubmit.InvokeAsync();
        }
    }
}

