<MudForm @ref="form" @bind-IsValid="@_isFormValid">
    <MudGrid Spacing="2">
        <MudItem xs="12" sm="8">
            <MudTextField @bind-Value="Produto.Nome"
                          For="@(() => Produto.Nome)"
                          Label="Nome do Produto"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Required="true"
                          Immediate="true" />
        </MudItem>
        
        @* Preço com Formatação de Moeda *@
        <MudItem xs="12" sm="4">
            <MudNumericField @bind-Value="Produto.Preco"
                             For="@(() => Produto.Preco)"
                             Label="Preço"
                             Variant="Variant.Outlined"
                             Margin="Margin.Dense"
                             Format="N2"
                             Culture="@_brazilCulture"
                             Adornment="Adornment.Start"
                             AdornmentText="R$"
                             HideSpinButtons="true"
                             InputMode="InputMode.numeric"
                             RequiredError="O preço é obrigatório"
                             ErrorText="Informe um valor numérico válido" />
        </MudItem>
        
        @* Linha 2: Descrição *@
        <MudItem xs="12">
            <MudTextField @bind-Value="Produto.Descricao"
                          For="@(() => Produto.Descricao)"
                          Label="Descrição Detalhada"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Lines="3" 
                          Required="true" />
        </MudItem>

        @* Linha 3: Categoria com Autocomplete *@
        <MudItem xs="12" sm="6">
            <MudAutocomplete T="int"
                             Label="Categoria"
                             @bind-Value="Produto.CategoriaId"
                             For="@(() => Produto.CategoriaId)"
                             SearchFunc="@SearchCategoria"
                             ToStringFunc="@(id => Categorias?.FirstOrDefault(c => c.CategoriaId == id)?.Name)"
                             Variant="Variant.Outlined"
                             Margin="Margin.Dense"
                             AnchorOrigin="Origin.BottomCenter"
                             TransformOrigin="Origin.TopCenter"
                             MaxHeight="250"
                             Dense="true"
                             Required="true"
                             Clearable="true"
                             ResetValueOnEmptyText="true"
                             Placeholder="Selecione ou digite para buscar">
            </MudAutocomplete>
        </MudItem>
        <MudItem xs="12" Class="d-flex justify-space-between align-center mt-1">
            <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="OnCancel">
                Cancelar
            </MudButton>
            
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="@(!_isFormValid || IsSaving)"
                       OnClick="HandleSubmit">
                @if (IsSaving)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Salvando...</MudText>
                }
                else
                {
                    <MudText>@ButtonText</MudText>
                }
            </MudButton>
        </MudItem>
    </MudGrid>
</MudForm>

@code {
    private MudForm? form;
    private bool _isFormValid;

    private System.Globalization.CultureInfo _brazilCulture = System.Globalization.CultureInfo.GetCultureInfo("pt-BR");

    [Parameter] public List<Categoria>? Categorias { get; set; }
    [Parameter] public Produto Produto { get; set; } = new();
    [Parameter] public bool IsSaving { get; set; }
    [Parameter] public string ButtonText { get; set; } = "Salvar";
    [Parameter] public EventCallback OnValidSubmit { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private Task<IEnumerable<int>> SearchCategoria(string value, CancellationToken token)
    {
        if (Categorias == null)
            return Task.FromResult(Enumerable.Empty<int>());

        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult(Categorias.Select(c => c.CategoriaId));

        return Task.FromResult(Categorias
            .Where(c => c.Name.Contains(value, StringComparison.InvariantCultureIgnoreCase))
            .Select(c => c.CategoriaId));
    }

    private async Task HandleSubmit()
    {
        await form!.ValidateAsync();
        if (form.IsValid)
        {
            await OnValidSubmit.InvokeAsync();
        }
    }
}

