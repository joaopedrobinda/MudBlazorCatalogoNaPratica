@page "/catalogo"

<MudAutocomplete T="int"
                 Label="Explorar Categorias"
                 Value="codigoCategoria"
                 ValueChanged="OnCategoriaChanged"
                 SearchFunc="@SearchCategoria"
                 ToStringFunc="@(id => categorias?.FirstOrDefault(c => c.CategoriaId == id)?.Name)"
                 Variant="Variant.Outlined"
                 Margin="Margin.Normal"
                 MaxItems="null"
                 Dense="true"
                 Adornment="Adornment.Start"
                 AdornmentIcon="@Icons.Material.Filled.FilterList"
                 AdornmentColor="Color.Primary"
                 HelperText="Escolha uma categoria para filtrar o catálogo abaixo"
                 Placeholder="Digite para buscar..."
                 Clearable="true"
                 Class="mb-6"
                 Style="background-color: white;">
    
    @* Template customizado para os itens da lista *@
    <ItemTemplate Context="id">
        <div class="d-flex align-center">
            <MudIcon Icon="@ObterIconeCategoria(id)" Color="Color.Default" Size="Size.Small" Class="mr-3" />
            <MudText Typo="Typo.body2">@categorias?.FirstOrDefault(c => c.CategoriaId == id)?.Name</MudText>
        </div>
    </ItemTemplate>
</MudAutocomplete>
<style>
    /* Efeito suave de elevação ao passar o mouse sobre o card */
    .card-hover {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }

        .card-hover:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 16px rgba(0,0,0,0.15) !important;
        }

    /* Trunca a descrição em 2 linhas para os cards não ficarem com tamanhos diferentes */
    .text-truncate-2-lines {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>

<MudItem xs="12" Class="mt-6">
    @if (carregando)
    {
        <MudGrid>
            @* Skeleton Loading: Mostra 4 cards falsos carregando *@
            @for (int i = 0; i < 4; i++)
            {
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <MudCard Elevation="2" Class="rounded-lg pa-2">
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="180px" Class="rounded" />
                        <MudCardContent>
                            <MudSkeleton Width="80%" Height="24px" Class="mb-2" />
                            <MudSkeleton Width="100%" Height="16px" Class="mb-1" />
                            <MudSkeleton Width="60%" Height="16px" Class="mb-4" />
                            <MudSkeleton Width="40%" Height="32px" />
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
    else if (codigoCategoria > 0 && !produtos.Any())
    {
        <MudPaper Elevation="0" Class="d-flex flex-column align-center justify-center pa-10 border-dashed border-2 mud-border-lines-default rounded-lg" Style="background-color: var(--mud-palette-background-grey);">
            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Default" Class="mb-3" />
            <MudText Typo="Typo.h6" Color="Color.Secondary">Nenhum produto encontrado</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Tente selecionar outra categoria para ver os itens disponíveis.</MudText>
        </MudPaper>
    }
    else if (produtos.Any())
    {
        <MudGrid>
            @foreach (var produto in produtos)
            {
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <MudCard Elevation="2" Class="rounded-lg card-hover h-100 d-flex flex-column">
                        
                        @* Área da Imagem com fundo sutil *@
                        <div class="pa-4 d-flex justify-center align-center" style="background-color: var(--mud-palette-background-grey); height: 200px;">
                            @if (!string.IsNullOrEmpty(produto.Imagem))
                            {
                                <MudImage Src="@produto.Imagem"
                                          Alt="@produto.Nome"
                                          ObjectFit="ObjectFit.Contain"
                                          Style="max-height: 100%; max-width: 100%;" />
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.ImageNotSupported" Color="Color.Default" Size="Size.Large" />
                            }
                        </div>

                        @* Conteúdo do Card (O flex-grow-1 empurra os botões sempre para o rodapé) *@
                        <MudCardContent Class="pa-4 flex-grow-1">
                            <MudText Typo="Typo.h6" Class="fw-bold mb-1">@produto.Nome</MudText>
                            
                            @* Assumindo que você tenha a propriedade Descricao. Se não tiver, pode remover. *@
                            <MudText Typo="Typo.body2" Color="Color.Default" Class="mb-3 text-truncate-2-lines">
                                @(produto.Descricao ?? "Nenhuma descrição disponível para este produto.")
                            </MudText>
                            
                            @* Assumindo que você tenha a propriedade Preco (decimal). O "C" formata para a moeda local. *@
                            <MudText Typo="Typo.h5" Color="Color.Primary" Class="fw-bold mt-auto">
                                @((produto.Preco > 0 ? produto.Preco : 0m).ToString("C"))
                            </MudText>
                        </MudCardContent>
                        
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
    else
    {
        <MudPaper Elevation="0" Class="d-flex flex-column align-center justify-center pa-10 border-dashed border-2 mud-border-lines-default rounded-lg" Style="background-color: var(--mud-palette-background-grey);">
            <MudIcon Icon="@Icons.Material.Filled.Category" Size="Size.Large" Color="Color.Primary" Class="mb-3" />
            <MudText Typo="Typo.h6" Color="Color.Primary">Bem-vindo ao Catálogo!</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Selecione uma categoria acima para começar a explorar nossos produtos.</MudText>
        </MudPaper>
    }
</MudItem>

@code {
    List<Categoria>? categorias;
    List<Produto> produtos = new();
    private bool carregando = false;
    private int codigoCategoria;

    protected override async Task OnInitializedAsync()
    {
        categorias = await Http.GetFromJsonAsync<List<Categoria>>("api/categoria/all");
    }

    private async Task OnCategoriaChanged(int id)
    {
        codigoCategoria = id;
        await CarregaProdutos();
    }

    private async Task CarregaProdutos()
    {
        if (codigoCategoria > 0)
        {
            try
            {
                carregando = true;
                produtos.Clear(); // Limpa a lista anterior antes de carregar a nova
                StateHasChanged();

                // DICA: Abra o Console do Navegador (F12) para ver se esta URL está correta
                var url = $"api/produto/categorias/{codigoCategoria}";
            
                var resultado = await Http.GetFromJsonAsync<List<Produto>>(url);
            
                produtos = resultado ?? new List<Produto>();
            }
            catch (Exception ex)
            {
                // Se cair aqui, o erro aparecerá no console do navegador
                Console.WriteLine($"Erro ao carregar produtos: {ex.Message}");
                produtos = new List<Produto>();
            }
            finally
            {
                carregando = false;
                StateHasChanged(); // CRUCIAL: Notifica a tela que os dados chegaram
            }
        }
        else
        {
            produtos.Clear();
            StateHasChanged();
        }
    }

    private Task<IEnumerable<int>> SearchCategoria(string value, CancellationToken token)
    {
        if (categorias == null)
            return Task.FromResult(Enumerable.Empty<int>());

        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult(categorias.Select(c => c.CategoriaId));

        return Task.FromResult(categorias
            .Where(c => c.Name.Contains(value, StringComparison.InvariantCultureIgnoreCase))
            .Select(c => c.CategoriaId));
    }
    private string ObterIconeCategoria(int id)
    {
        var nome = categorias?.FirstOrDefault(c => c.CategoriaId == id)?.Name?.ToLower();
    
        return nome switch
        {
            "livros" => Icons.Material.Filled.MenuBook,
            "eletrônicos" => Icons.Material.Filled.Devices,
            "games" => Icons.Material.Filled.SportsEsports,
            "vestuário" => Icons.Material.Filled.Checkroom,
            _ => Icons.Material.Filled.Label // Ícone padrão
        };
    }
}