@page "/categorias"
@using MudBlazorCatalogoNaPratica.Client.Shared

<div class="d-flex justify-space-between align-center mt-6">
    <div>
        <MudText Typo="Typo.h4" Color="Color.Primary">Categorias</MudText>
        <MudDivider Class="mb-6" />
    </div>
    
    <MudButton Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.Add"
               Color="Color.Primary"
               Href="/categoria/create">
        Nova Categoria
    </MudButton>
</div>

<MudTable T="Categoria" ServerData="ServerReload" @ref="_table" Hover="true" Dense="true">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Categorias</MudText>
        <MudSpacer />
        <MudTextField T="string" 
                      Placeholder="Pesquisar..." 
                      Adornment="Adornment.Start" 
                      AdornmentIcon="@Icons.Material.Filled.Search" 
                      IconSize="Size.Medium" 
                      Class="mt-0"
                      Clearable="true"
                      DebounceInterval="500"
                      OnDebounceIntervalElapsed="OnSearch" />
    </ToolBarContent>
    <HeaderContent>
        <MudTh>Nome</MudTh>
        <MudTh>Descrição</MudTh>
        <MudTh>Ações</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Nome">@context.Name</MudTd>
        <MudTd DataLabel="Descricao">@context.Descricao</MudTd>
        <MudTd DataLabel="Ações">
            <div class="d-flex">
                <MudTooltip Text="Editar Categoria">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   Href="@($"/categoria/edit/{context.CategoriaId}")" />
                </MudTooltip>
    
                <MudTooltip Text="Excluir Categoria">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   OnClick="@(() => DeletarCategoria(context.CategoriaId))" />
                </MudTooltip>
            </div>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudAlert Severity="Severity.Info" Dense="true" Class="my-2">Nenhuma categoria encontrada.</MudAlert>
    </NoRecordsContent>
     <LoadingContent>
        <MudText>Carregando...</MudText>
    </LoadingContent>
    <PagerContent>
        <div class="d-flex justify-center py-3">
            <MudTablePager InfoFormat="{first_item}-{last_item} de {all_items}" RowsPerPageString="Linhas por página:" />
        </div>
    </PagerContent>
</MudTable>

@code {
    private MudTable<Categoria> _table;
    private string _searchString;

    private void OnSearch(string text)
    {
        _searchString = text;
        _table.ReloadServerData();
    }

    private async Task<TableData<Categoria>> ServerReload(TableState state, CancellationToken token)
    {
        try
        {
            var pagina = state.Page + 1;
            var quantidadePorPagina = state.PageSize;
            var termoBusca = _searchString;

            var httpResponse = await Http.GetAsync($"/api/categoria?pagina={pagina}&quantidadePorPagina={quantidadePorPagina}&termoBusca={termoBusca}", token);

            if (httpResponse.IsSuccessStatusCode)
            {
                var totalItens = int.Parse(httpResponse.Headers.GetValues("quantidadeRegistrosTotal").FirstOrDefault() ?? "0");
                var responseString = await httpResponse.Content.ReadAsStringAsync();
                
                var categorias = JsonSerializer.Deserialize<List<Categoria>>(responseString,
                    new JsonSerializerOptions
                        {
                            PropertyNameCaseInsensitive = true
                        });

                return new TableData<Categoria> { TotalItems = totalItens, Items = categorias };
            }
        }
        catch (OperationCanceledException)
        {
            // Requisição cancelada pelo MudBlazor (ex: usuário navegou rápido demais)
        }
        catch (Exception)
        {
            Snackbar.Add("Erro ao carregar dados", Severity.Error);
        }

        return new TableData<Categoria> { TotalItems = 0, Items = new List<Categoria>() };
    }

    private async Task DeletarCategoria(int categoriaId)
    {
        var parameters = new DialogParameters<DialogoConfirmacao>
        {
            { x => x.ContentText, "Tem certeza que deseja deletar esta categoria?" },
            { x => x.ButtonText, "Deletar" },
            { x => x.Color, Color.Error }
        };

        var dialog = await DialogService.ShowAsync<DialogoConfirmacao>("Confirmar Exclusão", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            var response = await Http.DeleteAsync($"/api/categoria/{categoriaId}");

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Deletado!", Severity.Success);
                await _table.ReloadServerData();
            }
        }
    }
}