@page "/categoria/edit/{categoriaid:int}"

<div class="mt-6">
    <MudText Typo="Typo.h4" Color="Color.Primary">Editar</MudText>
    <MudDivider Class="mb-6" />
</div>

<MudPaper Class="pa-4" Elevation="3">
    @if (_categoria == null)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else
    {
        <CategoriaForm Categoria="_categoria"
                       IsSaving="_isSaving"
                       ButtonText="Alterar"
                       OnValidSubmit="EditarCategoriaAsync"
                       OnCancel="Voltar" />
    }
</MudPaper>

@code {
    [Parameter] public int categoriaid { get; set; }
    private Categoria? _categoria;
    private bool _isSaving;

    protected override async Task OnParametersSetAsync()
    {
        _categoria = await Http.GetFromJsonAsync<Categoria>($"api/categoria/{categoriaid}");
    }

    private async Task EditarCategoriaAsync()
    {
        try
        {
            _isSaving = true;
            var response = await Http.PutAsJsonAsync($"api/categoria/{categoriaid}", _categoria);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Categoria editada!", Severity.Success);
                Voltar();
            }
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void Voltar() => NavigationManager.NavigateTo("/categorias");
}
