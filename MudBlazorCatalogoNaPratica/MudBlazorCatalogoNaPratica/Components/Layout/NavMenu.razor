    <MudNavLink Href="categorias" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Outlined.Category">Categorias</MudNavLink>
    <MudNavLink Href="produtos" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Outlined.Inventory2">Produtos</MudNavLink>
